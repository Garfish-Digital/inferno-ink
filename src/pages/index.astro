---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section id="hero" class="hero">
    <div class="container">
      <div class="hero-content">
        <h1 class="hero-title">INFERNO INK</h1>
        <p class="hero-tagline">Hell Hath No Fury</p>
        <p class="hero-description">
          Extreme body artistry from those who've been there and back.
        </p>
        <a href="#contact" class="hero-cta">Book Now</a>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="section services">
    <div class="container">
      <h2 class="section-title">Our Specialties</h2>
      <div class="services-grid">
        <div class="service-card">
          <h3>Custom Designs</h3>
          <p>Unique, personalized artwork tailored to your vision and story. Our artists work closely with you to create one-of-a-kind pieces.</p>
        </div>
        <div class="service-card">
          <h3>Traditional</h3>
          <p>Classic American traditional with bold lines and vibrant colors. Timeless designs that honor tattoo heritage.</p>
        </div>
        <div class="service-card">
            <h3>Blackwork</h3>
            <p>Striking black ink designs from geometric patterns to illustrative styles. Bold, dramatic artwork that makes a statement.</p>
        </div>
        <div class="service-card">
          <h3>Cover-ups</h3>
          <p>Transform old tattoos into stunning new masterpieces. Expert cover-up artistry that breathes new life into existing ink.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Artists Section -->
  <section id="artists" class="section artists">
    <div class="container">
      <h2 class="section-title">Master Artists</h2>
      <div class="artists-grid">
        <div class="artist-card artist-featured">
          <div class="artist-image">
            <img src="/images/artist-phoenix.webp" alt="Lou Martinez - Color & Traditional Tattoo Artist" />
          </div>
          <h3>Lou Martinez</h3>
          <p class="artist-specialty">Color & Traditional</p>
          <p>Award-winning artist known for vibrant colors and traditional American style. Bringing classic tattoo artistry to modern designs.</p>
        </div>
        <div class="artist-card">
          <div class="artist-image">
            <img src="/images/artist-raven.webp" alt="Avery Blackthorne - Blackwork & Gothic Tattoo Artist" />
          </div>
          <h3>Avery Blackthorne</h3>
          <p class="artist-specialty">Blackwork & Gothic</p>
          <p>15+ years specializing in dark art and intricate blackwork designs. Master of gothic imagery and bold geometric patterns.</p>
        </div>
        <div class="artist-card">
          <div class="artist-image">
            <img src="/images/artist-ash.webp" alt="Ashton Starke - Realism & Portrait Tattoo Artist" />
          </div>
          <h3>Ashton Starke</h3>
          <p class="artist-specialty">Realism & Portraits</p>
          <p>Masterful realism artist bringing photos to life on skin. Specializing in photorealistic portraits and detailed artwork.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Section -->
  <section id="gallery" class="section gallery">
    <div class="container">
      <h2 class="section-title">Gallery</h2>
      <div class="gallery-grid">
        <div class="gallery-item">
          <img src="/images/gallery-1.webp" alt="Custom Blackwork Tattoo Design" />
          <!-- <div class="gallery-overlay">
            <span class="overlay-style">Blackwork</span>
          </div> -->
        </div>
        <div class="gallery-item">
          <img src="/images/gallery-2.webp" alt="Traditional Color Tattoo Art" />
          <!-- <div class="gallery-overlay">
            <span class="overlay-style">Traditional</span>
          </div> -->
        </div>
        <div class="gallery-item">
          <img src="/images/gallery-3.webp" alt="Realistic Portrait Tattoo" />
          <!-- <div class="gallery-overlay">
            <span class="overlay-style">Realism</span>
          </div> -->
        </div>
        <div class="gallery-item">
          <img src="/images/gallery-4.webp" alt="Gothic Sleeve Tattoo Design" />
          <!-- <div class="gallery-overlay">
            <span class="overlay-style">Gothic</span>
          </div> -->
        </div>
        <div class="gallery-item">
          <img src="/images/gallery-5.webp" alt="Geometric Tattoo Pattern" />
          <!-- <div class="gallery-overlay">
            <span class="overlay-style">Geometric</span>
          </div> -->
        </div>
        <div class="gallery-item">
          <img src="/images/gallery-6.webp" alt="Fire-themed Tattoo Artwork" />
          <!-- <div class="gallery-overlay">
            <span class="overlay-style">Illustrative</span>
          </div> -->
        </div>
        <div class="gallery-item">
          <img src="/images/gallery-7.webp" alt="Geometric Tattoo Pattern" />
          <!-- <div class="gallery-overlay">
            <span class="overlay-style">Fine Line</span>
          </div> -->
        </div>
        <div class="gallery-item">
          <img src="/images/gallery-8.webp" alt="Fire-themed Tattoo Artwork" />
          <!-- <div class="gallery-overlay">
            <span class="overlay-style">Cover-up</span>
          </div> -->
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="section contact">
    <canvas id="hell-canvas"></canvas>
    <div class="heat-haze" aria-hidden="true"></div>
    <div class="container">
      <h2 class="section-title">Book Your Session</h2>
      <div class="contact-content">
        <div class="contact-info">
          <h3>Reach Us</h3>
          <p>537 Paper Street<br>Wilmington, CA 90744</p>
          <p><strong>Phone:</strong> (555) INF-ERNO</p>
          <p><strong>Email:</strong> book@infernoink.com</p>
          <div class="hours">
            <h4>Studio Hours</h4>
            <p>Monday - Saturday: 12PM - 10PM<br>Sunday: 1PM - 8PM</p>
          </div>
        </div>
        <div class="contact-form">
          <form>
            <input type="text" placeholder="Your Name" required>
            <input type="email" placeholder="Email Address" required>
            <input type="tel" placeholder="Phone Number">
            <select required>
              <option value="">Select Your Artist</option>
              <option value="avery">Avery Blackthorne</option>
              <option value="lou">Lou Martinez</option>
              <option value="ashton">Ashton Starke</option>
            </select>
            <textarea placeholder="Describe your tattoo idea..." rows="5" required></textarea>
            <button type="submit" class="submit-btn">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  @use '../styles/_variables' as *;

  .section-title {
    font-size: clamp(1.25rem, 3vw, 2rem);
  }

  .hero {
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(135deg, $ash 0%, $cinder 100%);
    position: relative;
    overflow: hidden;

    // Add subtle texture overlay
    &::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 30% 50%, rgba($heat-core, 0.1) 0%, transparent 50%),
                  radial-gradient(circle at 70% 50%, rgba($heat-mid, 0.05) 0%, transparent 50%);
      pointer-events: none;
    }

    .container {
      position: relative;
      z-index: 1;
    }

    .hero-content {
      max-width: 800px;
      margin: 0 auto;
    }

    .hero-title {
      font-family: $font-display;
      font-size: clamp(3rem, 8vw, 6rem);
      font-weight: 700;
      color: $bone;
      margin-bottom: $space-6;
      letter-spacing: 0.1em;
    }

    .hero-tagline {
      font-family: $font-display;
      font-size: clamp(1.25rem, 3vw, 2rem);
      color: $heat-mid;
      margin-bottom: $space-8;
      font-weight: 500;
      letter-spacing: 0.05em;
    }

    .hero-description {
      font-size: 1.125rem;
      color: $bone-dim;
      margin-bottom: $space-12;
      line-height: 1.8;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
      padding: 0 1rem;
    }

    .hero-cta {
      display: inline-block;
      padding: $space-4 $space-12;
      font-family: $font-body;
      font-weight: 600;
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: $tracking-wide;
      color: $bone;
    //   color: $heat-mid;
      text-decoration: none;
      background: $ash;
      border: 2px solid transparent;
      border-image: linear-gradient(135deg, $heat-deep, $heat-bright) 1;
      border-radius: 0; // border-image doesn't work with border-radius
      transition: color $t-base $ease-heat;

      &:hover {
        color: $heat-glow;
        border-image: linear-gradient(90deg, $heat-deep, $heat-bright) 1;
      }

      &:active {
        color: $heat-mid;
      }
    }
  }

  // Section vertical spacing (global.scss .section is Astro-scoped to BaseLayout, doesn't reach here)
  .services,
  .artists,
  .gallery,
  .contact {
    padding-top: $space-32;
    padding-bottom: $space-32;
  }

  // Services Section
  .services {
    background: linear-gradient(180deg, $cinder 0%, $ash 100%);

    .section-title {
      font-family: $font-display;
      text-align: center;
      margin-bottom: $space-32;
      color: $bone;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: $space-12;
      padding: 0 $space-12;
    }

    .service-card {
      background: linear-gradient(135deg, $cinder 0%, $iron 100%);
      margin: $space-12;
      padding: $space-12;
    //   border-radius: $radius-base;
      text-align: center;
      border: 1px solid rgba($heat-core, 0.2);
      // Specific properties only — `all` would filter GSAP's inline transform/opacity
      // through this CSS easing curve and create a punch at the end of the entrance.
      transition: border-color $t-fast $ease-heat;
      position: relative;
      overflow: hidden;

      &::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba($heat-core, 0.05) 0%, rgba($heat-mid, 0.05) 100%);
        opacity: 0;
        transition: all $t-fast $ease-heat;
      }

      // Entrance hairline — drives the architectural reveal
      &::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: $heat-core;
        transform: scaleX(var(--hairline-scale, 0));
        transform-origin: left center;
        opacity: var(--hairline-opacity, 0);
        pointer-events: none;
        z-index: 2;
      }

      &:hover {
        // transform: translateY(-5px);
        border-color: rgba($heat-core, 0.4);
        // box-shadow: 0 10px 25px rgba($void, 0.2);

        &::before {
          opacity: 1;
        }

      }

      h3 {
        font-family: $font-display;
        color: $heat-mid;
        margin-bottom: $space-4;
        font-size: 1.5rem;
        font-weight: 600;
      }

      p {
        color: $bone-dim;
        line-height: 1.6;
        margin-bottom: 0;
      }
    }
  }

  // Artists Section
  .artists {
    background: linear-gradient(180deg, $ash 0%, $cinder 100%);

    .section-title {
      font-family: $font-display;
      text-align: center;
      margin-bottom: $space-32;
      color: $bone;
    }

    .artists-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: $space-12;
      padding: 0 1rem;
      justify-items: center;
    }

    .artist-featured {
      grid-column: 1 / -1;
      max-width: 480px;
      width: 100%;
    }

    .artist-card:not(.artist-featured) {
      max-width: 480px;
      width: 100%;
    }

    .artist-card {
      text-align: center;
      padding: $space-8;
      background: rgba($iron, 0.5);
    //   border-radius: $radius-base;
      // Specific properties only — `all` would filter GSAP's inline transform/opacity
      // through this CSS easing curve and create a punch at the end of the entrance.
      transition: border-color $t-base $ease-heat;
      border: 1px solid rgba($heat-mid, 0.2);
      position: relative;
      overflow: hidden;

      &::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba($heat-core, 0.05) 0%, rgba($heat-mid, 0.05) 100%);
        opacity: 0;
        transition: all $t-fast $ease-heat;
      }

      // Entrance hairline — drives the architectural reveal
      &::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: $heat-core;
        transform: scaleX(var(--hairline-scale, 0));
        transform-origin: left center;
        opacity: var(--hairline-opacity, 0);
        pointer-events: none;
        z-index: 2;
      }

      &:hover {
        transform: scale(1.02);
        border-color: rgba($heat-mid, 0.4);
        // box-shadow: 0 10px 25px rgba($void, 0.2);

        &::before {
          opacity: 1;
        }
      }

      .artist-image {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        margin: 0 auto $space-6;
        border: 3px solid rgba($heat-mid, 0.3);
        transition: all $t-slow $ease-heat;
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, $heat-core 0%, $heat-mid 100%);

        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          object-position: center;
          transition: all $t-slow $ease-heat;
          border-radius: 50%;
          position: relative;
          z-index: 1; // Above placeholder
        }

        &:hover img {
          transform: scale(1.1);
          filter: brightness(1.1) contrast(1.1);
        }

      }

      h3 {
        font-family: $font-display;
        color: $bone;
        margin-bottom: $space-2;
        font-size: 1.5rem;
        font-weight: 600;
      }

      .artist-specialty {
        color: $heat-mid;
        font-weight: 600;
        margin-bottom: $space-4;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.9rem;
      }

      p:last-child {
        color: $bone-dim;
        line-height: 1.6;
        margin-bottom: 0;
      }
    }
  }

  // Gallery Section
  .gallery {
    background: linear-gradient(180deg, $cinder 0%, $ash 100%);

    .section-title {
      font-family: $font-display;
      text-align: center;
      margin-bottom: $space-32;
      color: $bone;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: $space-32;
      padding: 0 $space-16;
      max-width: 1200px;
      margin: 0 auto;
    }

    .gallery-item {
      aspect-ratio: 1;
    //   border-radius: $radius-base;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      background: $cinder;
      border: 1px solid rgba($heat-core, 0.2);
      // Specific properties only — `all` would filter GSAP's inline transform/opacity
      // through this CSS easing curve and create a punch at the end of the entrance.
      transition: border-color $t-fast $ease-heat;

      // Subtle heat tint — matches the hover language used on service + artist cards
      &::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba($heat-core, 0.05) 0%, rgba($heat-mid, 0.05) 100%);
        opacity: 0;
        transition: opacity $t-fast $ease-heat;
        pointer-events: none;
        z-index: 1;
      }

      // Entrance hairline — same architectural reveal as the other cards
      &::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: $heat-core;
        transform: scaleX(var(--hairline-scale, 0));
        transform-origin: left center;
        opacity: var(--hairline-opacity, 0);
        pointer-events: none;
        z-index: 3;
      }

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        transition: transform $t-slow $ease-heat, filter $t-fast $ease-heat;
        // border-radius: $radius-base;
      }

      .gallery-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba($void, 0.6);
        display: flex;
        align-items: flex-end;
        justify-content: center;
        padding-bottom: $space-6;
        opacity: 0;
        transition: opacity $t-base $ease-heat;
        z-index: 2;
        // border-radius: $radius-base;

        .overlay-style {
          font-family: $font-display;
          font-size: $size-sm;
          letter-spacing: $tracking-widest;
          text-transform: uppercase;
          color: $bone;
          transform: translateY(12px);
          transition: transform $t-fast $ease-heat;
        }
      }

      &:hover {
        border-color: rgba($heat-core, 0.4);

        &::before {
          opacity: 1;
        }

        img {
          transform: scale(1.03);
          filter: brightness(0.8) contrast(1.1);
        }

        .gallery-overlay {
          opacity: 1;

          .overlay-style {
            transform: translateY(0);
          }
        }
      }
    }
  }

  // Contact Section
  .contact {
    background: linear-gradient(180deg, $ash 0%, $cinder 100%);
    position: relative;
    overflow: hidden;

    #hell-canvas {
      position: absolute;
      bottom: -25vh;                // bleed 25vh below the section, clipped by overflow:hidden
      left: -5%;
      width: 110%;                  // 10% horizontal bleed (5% each side)
      height: calc(100% + 25vh);    // grow taller so the top still meets the section top
      pointer-events: none;
      z-index: 0;
    }

    // Heat-haze layer — distorts the form/info text along the bottom edge.
    // Mask graduates the effect: full strength along the bottom, fading upward
    // so the top of the form remains crisp.
    .heat-haze {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 55%;
      pointer-events: none;
      z-index: 2;
      backdrop-filter: url(#heat-haze);
      -webkit-backdrop-filter: url(#heat-haze);
      mask-image: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0.5) 25%, rgba(0,0,0,0) 50%);
      -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0.5) 25%, rgba(0,0,0,0) 50%);
    }

    @media (prefers-reduced-motion: reduce) {
      .heat-haze {
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
      }
    }

    .container {
      position: relative;
      z-index: 1;
    }

    .section-title {
        font-family: $font-display;
      text-align: center;
      margin-bottom: $space-24;
      color: $bone;
    }

    .contact-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: $space-16;
      max-width: 1000px;
      margin: 0 auto;
    }

    .contact-info {
      h3 {
        font-family: $font-display;
        color: $heat-mid;
        margin-bottom: $space-6;
        font-size: 1.5rem;
        font-weight: 600;
      }

      p {
        margin-bottom: $space-4;
        line-height: 1.6;
        color: $bone-dim;

        strong {
          color: $heat-mid;
        }
      }

      .hours {
        margin-top: $space-8;
        padding: $space-6;
        background: rgba($iron, 0.5);
        // border-radius: $radius-base;
        border-left: 4px solid $heat-core;

        h4 {
          color: $heat-mid;
          margin-bottom: $space-4;
          font-family: $font-display;
          font-weight: 600;
        }

        p {
          margin-bottom: 0;
        }
      }
    }

    .contact-form {
      form {
        display: flex;
        flex-direction: column;
        gap: $space-6;
      }

      input,
      select,
      textarea {
        padding: $space-4;
        background: rgba($iron, 0.5);
        border: 1px solid rgba($heat-mid, 0.3);
        // border-radius: $radius-base;
        color: $bone;
        font-size: 1rem;
        font-family: $font-body;
        transition: all $t-base $ease-heat;

        &:focus {
          outline: none;
          border-color: $heat-mid;
          box-shadow: 0 0 10px rgba($heat-mid, 0.2);
          background: rgba($iron, 0.8);
        }

        &::placeholder {
          color: $bone-dim;
        }
      }

      select {
        cursor: pointer;
        // Safari-specific fixes for select height
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
        min-height: 48px; // Explicit minimum height for mobile
        height: auto; // Let it expand naturally
        line-height: 1.5;
        
        // Add custom dropdown arrow
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='rgba(255,255,255,0.7)' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6,9 12,15 18,9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 12px center;
        background-size: 16px;
        padding-right: 40px; // Space for arrow
        
        // Safari-specific height fix
        @supports (-webkit-appearance: none) {
          height: 48px; // Fixed height for WebKit browsers
          padding-top: 12px;
          padding-bottom: 12px;
        }
        
        // Style the placeholder option (first empty option)
        option[value=""] {
          color: $bone-dim;
        }
        
        // Ensure other options have normal text color
        option:not([value=""]) {
          color: $bone;
        }
        
        // When no option is selected (showing placeholder), use muted color
        &:invalid {
          color: $bone-dim;
        }
        
        // When a valid option is selected, use normal text color
        &:valid {
          color: $bone;
        }
      }


      textarea {
        resize: vertical;
        min-height: 120px;
      }

      .submit-btn {
        padding: $space-4 $space-8;
        background: rgb(0, 0, 0, .6);
        border: 1px solid transparent;
        border-image: linear-gradient(135deg, $heat-deep, $heat-bright) 1;
        border-radius: 0;
        font-size: 1rem;
        font-weight: 600;
        font-family: $font-body;
        text-transform: uppercase;
        letter-spacing: $tracking-wide;
        color: $bone;
        cursor: pointer;
        transition: all $t-base $ease-heat, box-shadow $t-base $ease-heat, transform $t-base $ease-heat;

        &:hover {
          color: $heat-glow;
        border-image: linear-gradient(90deg, $heat-deep, $heat-bright) 1;
        }

        &:active {
        color: $heat-mid;
        }
      }
    }
  }

  // Responsive adjustments
  @media (max-width: 768px) {
    .hero {
      .hero-description {
        font-size: 1rem;
        margin-bottom: $space-8;
      }

      .hero-cta {
        padding: $space-4 $space-8;
        font-size: 1rem;
      }
    }

    .services {
      .services-grid {
        grid-template-columns: 1fr;
      }
        .service-card {
            margin: $space-1;
        }
    }

    .artists {
      .artists-grid {
        grid-template-columns: 1fr;
        padding: 0 $space-12;
      }
    }

