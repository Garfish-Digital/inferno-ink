---
// MagicalCursor removed in Phase 5

export interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Inferno Ink | Tattoo & Body Modification",
  description = "Premium tattoo artistry with fire and passion. Custom designs, experienced artists, premium quality."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Viewport stabilization + hero pre-hide styles -->
    <style>
      /* Pre-hide hero elements before GSAP takes ownership.
         Matches setupInitialStates() in ScrollAnimationController.js
         so there is no visible flash between first paint and JS init. */
      .hero-title {
        clip-path: inset(0 100% 0 0);
      }
      .hero-tagline,
      .hero-description {
        opacity: 0;
        transform: translateY(30px);
      }
      .hero-cta {
        opacity: 0;
      }

      /* CSS-only viewport stabilization for mobile */
      @media (max-width: 768px) {
        html {
          height: 100vh;
          height: 100dvh;
        }
        body {
          position: relative;
          width: 100vw;
          min-height: 100vh;
          min-height: 100dvh;
          overflow-x: hidden;
        }
      }
    </style>
    
    <div class="brand-mark">
      <svg viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Shaft -->
        <line x1="20" y1="18" x2="20" y2="58" stroke="#000000" stroke-width="2.5"/>
        <!-- Center tine — pointed tip, longest -->
        <polygon points="20,0 18.5,20 21.5,20" fill="#000000"/>
        <!-- Left tine — pointed tip -->
        <polygon points="10,4 8.5,20 11.5,20" fill="#000000"/>
        <!-- Right tine — pointed tip -->
        <polygon points="30,4 28.5,20 31.5,20" fill="#000000"/>
        <!-- Crossbar -->
        <path d="M10 20 Q10 26 20 26 Q30 26 30 20" stroke="#000000" stroke-width="2" fill="none"/>
      </svg>
    </div>

    <!-- Heat haze SVG filter — referenced from .heat-haze backdrop-filter.
         Subtle fractalNoise displacement; baseFrequency breathes via spline-easing
         that approaches zero velocity at both ends so the loop seam is invisible. -->
    <svg class="hell-floor-filters" aria-hidden="true" focusable="false"
         width="0" height="0" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="heat-haze" x="-5%" y="-5%" width="110%" height="110%">
          <feTurbulence type="fractalNoise" baseFrequency="0.014 0.045" numOctaves="2" seed="3" result="noise">
            <animate attributeName="baseFrequency"
                     values="0.014 0.045;0.018 0.052;0.014 0.045"
                     keyTimes="0;0.5;1"
                     calcMode="spline"
                     keySplines="0.4 0 0.6 1; 0.4 0 0.6 1"
                     dur="28s" repeatCount="indefinite"/>
          </feTurbulence>
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="1.5" xChannelSelector="R" yChannelSelector="G"/>
        </filter>
      </defs>
    </svg>

    <main>
      <slot />
    </main>
    
    <script>
      import NeedleCursor from '../scripts/NeedleCursor.js';
      import ScrollAnimationController from '../scripts/ScrollAnimationController.js';
      import HellFloor from '../scripts/HellFloor.js';
      
      // Viewport stabilization utility
      function waitForViewportStability() {
        return new Promise((resolve) => {
          // Check if we're on mobile
          const isMobile = window.innerWidth <= 768;
          const baseDelay = isMobile ? 300 : 100; // Longer delay for mobile
          
          // Wait for initial paint
          requestAnimationFrame(() => {
            // Wait for layout calculations to complete
            setTimeout(() => {
              // Double-check viewport dimensions are stable
              const initialWidth = window.innerWidth;
              const initialHeight = window.innerHeight;
              
              setTimeout(() => {
                const finalWidth = window.innerWidth;
                const finalHeight = window.innerHeight;
                
                // If dimensions changed, wait a bit more
                if (Math.abs(finalWidth - initialWidth) > 10 || Math.abs(finalHeight - initialHeight) > 10) {
                  setTimeout(resolve, 200);
                } else {
                  resolve();
                }
              }, 100);
            }, baseDelay);
          });
        });
      }
      
      document.addEventListener('DOMContentLoaded', async () => {
        // Wait for viewport to stabilize before initializing animations
        await waitForViewportStability();
        
        // Initialize cursor (handles its own touch detection internally)
        const needleCursor = new NeedleCursor();
        window.needleCursor = needleCursor;

        // Initialize scroll animations
        const isMobile = window.innerWidth <= 768;
        setTimeout(() => {
          const scrollAnimations = new ScrollAnimationController();
          window.scrollAnimations = scrollAnimations;
        }, isMobile ? 100 : 50);

        // Initialize Hell Floor Three.js scene
        const hellFloor = new HellFloor();
        window.hellFloor = hellFloor;

      });
      
      // Cleanup on page unload
      window.addEventListener('beforeunload', () => {
        if (window.needleCursor) {
          window.needleCursor.destroy();
        }
        if (window.scrollAnimations) {
          window.scrollAnimations.destroy();
        }
        if (window.hellFloor) {
          window.hellFloor.destroy();
        }
      });
      
    </script>
  </body>
</html>

<style lang="scss">
  @use '../styles/global.scss';
  @use '../styles/_variables' as *;

  .brand-mark {
    position: fixed;
    top: 20px;
    left: 20px;
    width: 36px;
    z-index: 10002;
    pointer-events: none;

    svg {
      width: 100%;
      height: auto;
      display: block;
    }
  }

  // Heat-haze filter holder — kept off-canvas, only the <filter> def matters
  .hell-floor-filters {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    pointer-events: none;
  }

  // Garfish Digital Watermark
  .garfish-badge {
    font-family: "Courier Prime", "Courier New", Courier, monospace;
    position: fixed;
    bottom: 20px;
    left: 20px;
    z-index: 10001; // Higher than magical cursor
    pointer-events: auto;
    cursor: pointer !important; // Override cursor: none

    a {
      font-family: 'Courier New', monospace;
      font-size: 0.9rem; // Temporarily larger for debugging
      font-weight: 600;
      color: rgba(200, 200, 200, 0.8); // Temporarily more visible for debugging
      text-decoration: none;
      letter-spacing: 1px;
      transition: color 0.3s ease;
      display: block;
      white-space: nowrap;
      cursor: pointer !important; // Override cursor: none
      
      &:hover {
        color: rgba(240, 240, 240, 0.9); // More visible on hover
      }
    }
  }

  // Responsive adjustments
  @media (max-width: 640px) {
    .garfish-badge {
      bottom: 15px;
      left: 15px;
      
      a {
        font-size: 0.7rem;
      }
    }
  }
</style>